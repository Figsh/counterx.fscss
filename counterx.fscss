/* name "counterx/fscss" use "counter\-init" */
@import(exec(counter_array.fscss))
str(counter-init, "
    0%{
      content: '@arr.counter-before!.first0%'
    } 
    @arr.numlist[]%{
      content: '@arr.counter-before[2]@arr.numlist[]%';
    } 
    100%{
      content: '@arr.counter-before!.last';
    }"
)
